# ArenaMCP Configuration
# Copy this file to .env and add your API keys

# For Claude Code CLI backend (subscription, no API key required)
# Ensure claude.exe is on PATH or set a custom path here
CLAUDE_CODE_CMD=claude
# Optional: restart the session after N turns to avoid context rot
CLAUDE_CODE_MAX_TURNS=40
# Optional: response timeout in seconds
CLAUDE_CODE_TIMEOUT_S=12

# For Gemini CLI backend (subscription, no API key required)
# Ensure gemini is on PATH or set a custom path here
GEMINI_CLI_CMD=gemini
GEMINI_CLI_TIMEOUT_S=20
GEMINI_CLI_PERSISTENT=1
GEMINI_CLI_MAX_TURNS=40

# For Codex CLI backend via Azure OpenAI
# ArenaMCP launches codex from the repo root, so .codex/config.toml pins the
# provider to Azure and defaults Codex to gpt-5.4-pro.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Screenshot analysis (forced to Claude Code)
VISION_BACKEND_MODEL=sonnet
VISION_TIMEOUT_S=8

# For Ollama backend - no key needed
# Just install Ollama and run: ollama pull llama3.2

# Launcher maintenance
# Automatically trim Player.log before launch when MTGA is not already running.
ARENAMCP_TRIM_PLAYER_LOG=1
# Trim when Player.log exceeds this size in MB.
ARENAMCP_PLAYER_LOG_MAX_MB=64
# Keep the newest tail of Player.log at this size in MB.
ARENAMCP_PLAYER_LOG_KEEP_MB=8
